{
  "name": "neo-social-connect-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "client": "vite --host 127.0.0.1",
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "db:reset": "node server/index.js --reset-db"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "better-sqlite3": "^11.10.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "vite": "^6.3.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {}
}
